# ============================================================
# Production Environment Variables
# Copy to .env and fill in real values before deploying.
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=satellite_processor
POSTGRES_USER=sat
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- Application ---
DEBUG=false
STORAGE_PATH=/app/data

# --- Authentication (optional, leave empty to disable) ---
API_KEY=

# --- CORS ---
# Comma-separated origins. In production, set to your actual domain(s).
# Example: https://sat.example.com
CORS_ORIGINS=https://sat.example.com

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- Redis / Celery (password is interpolated from REDIS_PASSWORD in compose) ---
# These are set automatically by docker-compose.yml; override only if needed.
# REDIS_URL=redis://:PASSWORD@redis:6379/0

# --- Database URL (constructed from above, or override directly) ---
# For SSL connections (recommended when DB is not on same host):
# DATABASE_URL=postgresql+asyncpg://sat:CHANGE_ME@db/satellite_processor?ssl=require
# DATABASE_URL=postgresql+asyncpg://sat:CHANGE_ME@db/satellite_processor

# --- Core processor settings directory (container path) ---
SETTINGS_DIR=/app/data

# Grafana (defaults to "admin" if not set — change for production)
GRAFANA_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
